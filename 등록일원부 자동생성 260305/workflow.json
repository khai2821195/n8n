    {
      "id": "code-02",
      "name": "Code - 수업료 추출",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        180,
        300
      ],
      "parameters": {
        "jsCode": "const studentData = $json;\nconst prevData = $('Code - 수업회차 종료 체크').item.json;\n\n// Students DB에서 수업료 가져오기\nconst 수업료 = studentData.properties?.['수업료']?.number || 0;\n\nreturn [{\n  json: {\n    studentName: prevData.studentName,\n    studentPageId: prevData.studentPageId,\n    다음수업일ISO: prevData.다음수업일ISO,\n    year: prevData.year,\n    수업료\n  }\n}];"
      }
    },
    {
      "id": "notion-02",
      "name": "Notion - 올해 납부회차 조회",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [
        440,
        300
      ],
      "parameters": {
        "resource": "databasePage",
        "operation": "getAll",
        "databaseId": {
          "__rl": true,
          "value": "55aac51e-739c-4f8e-8709-03cb1eb252b6",
          "mode": "id"
        },
        "returnAll": true,
        "filterType": "manual",
        "filters": {
          "conditions": [
            {
              "key": "Students|relation",
              "condition": "relation",
              "returnValue": "={{ $('Code - 수업료 추출').item.json.studentPageId }}"
            }
          ]
        },
        "options": {}
      },
