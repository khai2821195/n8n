    {
      "id": "code-01",
      "name": "Code - 수업회차 종료 체크",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -340,
        300
      ],
      "parameters": {
        "jsCode": "const data = $json.body.data.properties;\n\n// 수업회차 종료 formula 값 확인\nconst 수업회차종료 = data['수업회차 종료']?.formula?.boolean || false;\n\nif (!수업회차종료) {\n  // 종료가 아니면 이후 노드 실행 안 함\n  return [];\n}\n\nconst studentName = data['학생이름(S)']?.formula?.string || '';\nconst studentPageId = data['Students']?.relation?.[0]?.id || '';\nconst 다음수업일Raw = data['다음수업일M']?.formula?.string || '';\n\n// 다음수업일 ISO 형식 확인\nlet 다음수업일ISO = '';\nif (다음수업일Raw.match(/^\\d{4}-\\d{2}-\\d{2}/)) {\n  다음수업일ISO = 다음수업일Raw.split('T')[0];\n} else if (다음수업일Raw.match(/^\\d{4}\\/\\d{2}\\/\\d{2}/)) {\n  다음수업일ISO = 다음수업일Raw.replace(/\\//g, '-').split('T')[0];\n} else if (다음수업일Raw.match(/^\\d{2}\\.\\d{2}\\(.*\\)$/)) {\n  // MM.DD(요일) 형식인 경우 연도 보정\n  const now = new Date();\n  const year = now.getFullYear();\n  const match = 다음수업일Raw.match(/^(\\d{2})\\.(\\d{2})/);\n  if (match) {\n    다음수업일ISO = `${year}-${match[1]}-${match[2]}`;\n  }\n}\n\nconst now = new Date();\nconst year = String(now.getFullYear()).slice(2); // '25', '26'\n\nreturn [{\n  json: {\n    studentName,\n    studentPageId,\n    다음수업일ISO,\n    year\n  }\n}];"
      }
    },
    {
