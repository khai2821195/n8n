    {
      "id": "code-03",
      "name": "Code - 납부회차 계산",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ],
      "parameters": {
        "jsCode": "const prev = $('Code - 수업료 추출').item.json;\nconst { studentName, studentPageId, 다음수업일ISO, year, 수업료 } = prev;\n\nconst allItems = $input.all();\n\n// 해당 학생의 올해 납부회차 레코드 필터링\nconst studentRecords = allItems.filter(item => {\n  const 회차 = item.json.properties?.['납부회차']?.select?.name || '';\n  return 회차.startsWith(year);\n});\n\n// 최대 회차 번호 계산\nconst existingNumbers = studentRecords.map(item => {\n  const val = item.json.properties?.['납부회차']?.select?.name || '';\n  return parseInt(val.slice(2), 10) || 0;\n});\n\nconst maxSeq = existingNumbers.length > 0 ? Math.max(...existingNumbers) : 0;\nconst nextSeq = maxSeq + 1;\nconst seqStr = String(nextSeq).padStart(2, '0');\nconst 납부회차 = year + seqStr; // 예: '2504'\nconst 레코드이름 = `${studentName} ${납부회차}`;\n\nreturn [{\n  json: {\n    studentPageId,\n    수업료,\n    다음수업일ISO,\n    납부회차,\n    레코드이름\n  }\n}];"
      }
    },
