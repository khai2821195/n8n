    {
      "parameters": {
        "jsCode": "const page = $input.first().json;\nconst scheduleProp = page.properties?.['수업일정'];\nlet startDate = null;\nlet endDate = null;\n\nif (scheduleProp?.type === 'date' && scheduleProp?.date) {\n  startDate = scheduleProp.date.start;\n  endDate = scheduleProp.date.end || null;\n}\n\nif (!startDate) {\n  return [{ json: { skip: true, reason: '수업일정 날짜 없음', studentIds: [] } }];\n}\n\n// --- ENHANCED MULTI-SELECT COURSE EXTRACTION ---\nconst courseProp = page.properties?.['과정'];\nlet courseValue = null;\n\nif (courseProp) {\n  if (courseProp.type === 'select') {\n    courseValue = [courseProp.select?.name]; // Wrap in array for consistency\n  } else if (courseProp.type === 'multi_select') {\n    courseValue = courseProp.multi_select?.map(s => s.name) || [];\n  } else if (courseProp.type === 'relation') {\n    courseValue = courseProp.relation?.map(r => r.id) || [];\n  } else if (courseProp.type === 'rich_text') {\n    courseValue = [courseProp.rich_text?.[0]?.plain_text];\n  } else if (courseProp.type === 'rollup') {\n    courseValue = courseProp.rollup?.map(r => r.name || r.id) || [];\n  }\n}\n\nconst studentStudyProp = page.properties?.['Student_Study'];\nlet studentIds = [];\nif (studentStudyProp?.type === 'relation' && studentStudyProp?.relation?.length > 0) {\n  studentIds = studentStudyProp.relation.map(r => r.id);\n}\n\nif (studentIds.length === 0) {\n  return [{ json: { skip: true, reason: '연결된 Student_Study 레코드 없음', studentIds: [] } }];\n}\n\nreturn studentIds.map(id => ({\n  json: { skip: false, studentPageId: id, startDate, endDate, course: courseValue }\n}));"
      },
