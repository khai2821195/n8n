    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const results = [];\nfor (const item of $input.all()) {\n  const p = item.json;\n  if (!p.id) continue;\n  const props = p.properties || {};\n  const classId = (props['Class']?.relation || [])[0]?.id || null;\n  const dateStart = props['수업일정']?.date?.start || '';\n  const classStudyName = (props['수업구분']?.title || []).map(t => t.plain_text).join('');\n  const students = props['Students']?.relation || [];\n  if (students.length === 0) continue;\n  for (const s of students) {\n    results.push({ json: { studentId: s.id, classStudyId: p.id, classId, dateStart, classStudyName } });\n  }\n}\nif (results.length === 0) return [{ json: { skip: true, message: '배정할 학생 없음' } }];\nreturn results;"
