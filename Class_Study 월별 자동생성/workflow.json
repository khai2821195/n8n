    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const aggregateOutput = $input.first();\nconst allCreated = aggregateOutput.json.data || [];\nif (allCreated.length === 0) return [{ json: { skip: true, message: '생성된 레코드 없음' } }];\nconst groups = {};\nfor (const item of allCreated) {\n  const props = item.properties || {};\n  const classId = (props['Class']?.relation || [])[0]?.id || 'unknown';\n  const dateStr = props['수업일정']?.date?.start || '';\n  const pageId = item.id;\n  if (!pageId) continue;\n  if (!groups[classId]) groups[classId] = [];\n  groups[classId].push({ pageId, dateStr });\n}\nconst pairs = [];\nfor (const classId of Object.keys(groups)) {\n  const items = groups[classId].sort((a, b) => a.dateStr.localeCompare(b.dateStr));\n  for (let i = 0; i < items.length - 1; i++) {\n    if (items[i].pageId && items[i+1].pageId) pairs.push({ json: { currentId: items[i].pageId, nextId: items[i+1].pageId } });\n  }\n}\nif (pairs.length === 0) return [{ json: { skip: true, message: '연결할 쌍 없음' } }];\nreturn pairs;"
      },
