    {
      "parameters": {
        "jsCode": "function parseHour(str) {\n  const m = (str || '').match(/(\\d+)시/);\n  return m ? parseInt(m[1], 10) : 0;\n}\nconst DAY_MAP = { '일': 0, '월': 1, '화': 2, '수': 3, '목': 4, '금': 5, '토': 6 };\nconst now = new Date();\nconst targetYear = now.getMonth() === 11 ? now.getFullYear() + 1 : now.getFullYear();\nconst targetMonth = now.getMonth() === 11 ? 1 : now.getMonth() + 2;\nfunction toKSTDatetime(date, hour) {\n  const yyyy = date.getFullYear();\n  const mm = String(date.getMonth() + 1).padStart(2, '0');\n  const dd = String(date.getDate()).padStart(2, '0');\n  const hh = String(hour).padStart(2, '0');\n  return yyyy + '-' + mm + '-' + dd + 'T' + hh + ':00:00+09:00';\n}\nfunction getDatesInMonth(year, month, dow) {\n  const dates = [];\n  const d = new Date(year, month - 1, 1);\n  while (d.getMonth() === month - 1) {\n    if (d.getDay() === dow) dates.push(new Date(d));\n    d.setDate(d.getDate() + 1);\n  }\n  return dates;\n}\nconst aggregated = $input.first();\nconst classList = aggregated.json.data || [];\nconst records = [];\nfor (const cls of classList) {\n  const props = cls.properties || {};\n  const classId = cls.id;\n  const 반명 = (props['반명']?.title || []).map(t => t.plain_text).join('');\n  const 수업구분Raw = props['수업구분']?.select?.name || '';\n  const totalCount = parseInt((수업구분Raw.match(/(\\d+)/) || ['0','0'])[1], 10);\n  if (totalCount === 0 || !반명) continue;\n  const studentIds = (props['Students']?.relation || []).map(r => r.id);\n  const slots = [];\n  for (let i = 1; i <= 3; i++) {\n    const days = (props['수업 ' + i]?.multi_select || []).map(s => s.name);\n    const times = (props['시간 ' + i]?.multi_select || []).map(s => s.name);\n    for (const day of days) slots.push({ day, hour: times.length > 0 ? parseHour(times[0]) : 0 });\n  }\n  if (slots.length === 0) continue;\n  const allDates = [];\n  for (let si = 0; si < slots.length; si++) {\n    const slot = slots[si];\n    if (!(slot.day in DAY_MAP)) continue;\n    const dates = getDatesInMonth(targetYear, targetMonth, DAY_MAP[slot.day]);\n    for (const d of dates) allDates.push({ date: d, hour: slot.hour, slotIdx: si });\n  }\n  allDates.sort((a, b) => a.date - b.date);\n  const dayWeekCount = {};\n  let seq = 0;\n  for (const entry of allDates) {\n    if (seq >= totalCount) break;\n    seq++;\n    const dow = entry.date.getDay();\n    dayWeekCount[dow] = (dayWeekCount[dow] || 0) + 1;\n    const weekNum = dayWeekCount[dow];\n    records.push({ json: { title: 반명 + ' ' + targetMonth + '월 ' + weekNum + '-' + (entry.slotIdx + 1), datetime: toKSTDatetime(entry.date, entry.hour), classId, studentIds, 반명, seq } });\n  }\n}\nif (records.length === 0) records.push({ json: { skip: true, message: '생성할 레코드 없음' } });\nreturn records;"
      },
