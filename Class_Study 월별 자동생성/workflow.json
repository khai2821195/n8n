    {
      "parameters": {
        "jsCode": "const candidates = $('Code - 수업일정 계산').all();\nconst httpResponse = $input.first().json;\nconst existingItems = httpResponse.results || [];\nconst now = new Date();\nconst targetYear = now.getMonth() === 11 ? now.getFullYear() + 1 : now.getFullYear();\nconst targetMonth = now.getMonth() === 11 ? 1 : now.getMonth() + 2;\nconst monthStart = new Date(targetYear, targetMonth - 1, 1).getTime();\nconst monthEnd = new Date(targetYear, targetMonth, 1).getTime();\nconst existingSet = new Set();\nconst classLastKajeong = {};\nfor (const item of existingItems) {\n  const props = item.properties || {};\n  const classId = (props['Class']?.relation || [])[0]?.id || null;\n  const dateStr = props['수업일정']?.date?.start || '';\n  if (!classId || !dateStr) continue;\n  const dateTs = new Date(dateStr).getTime();\n  if (dateTs >= monthStart && dateTs < monthEnd) existingSet.add(classId + '__' + dateStr.split('T')[0]);\n  const 과정Names = (props['과정']?.multi_select || []).map(s => s.name);\n  if (과정Names.length > 0) {\n    if (!classLastKajeong[classId] || dateStr > classLastKajeong[classId].date) {\n      classLastKajeong[classId] = { date: dateStr, 과정: 과정Names };\n    }\n  }\n}\nconst results = [];\nfor (const c of candidates) {\n  if (c.json.skip) continue;\n  const dateOnly = (c.json.datetime || '').split('T')[0];\n  const key = c.json.classId + '__' + dateOnly;\n  if (!existingSet.has(key)) {\n    const lastKajeong = classLastKajeong[c.json.classId];\n    results.push({ json: Object.assign({}, c.json, { 과정: lastKajeong ? lastKajeong.과정 : [] }) });\n  }\n}\nif (results.length === 0) results.push({ json: { skip: true, message: '모두 중복 - 생성 없음' } });\nreturn results;"
      },
