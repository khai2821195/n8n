          "jsonBody": "={{ JSON.stringify({ filter: { and: [ { property: '수업일정', date: { on_or_after: (() => { const d = new Date(); const y = d.getMonth() === 11 ? d.getFullYear() + 1 : d.getFullYear(); const m = d.getMonth() === 11 ? 1 : d.getMonth() + 2; return new Date(y, m - 1, 1).toISOString().split('T')[0]; })() } }, { property: '수업일정', date: { before: (() => { const d = new Date(); const y = d.getMonth() === 11 ? d.getFullYear() + 1 : d.getFullYear(); const m = d.getMonth() === 11 ? 1 : d.getMonth() + 2; return new Date(y, m, 1).toISOString().split('T')[0]; })() } } ] }, page_size: 100 }) }}",
