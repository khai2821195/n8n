        "name": "Code - 납부회차 계산",
        "parameters": {
          "jsCode": "const prev = $('Code - 이름 병합').item.json;\nconst { studentName, studentStudyPageId, studentPageId, isoDate, year, fee } = prev;\nconst pages = $input.first().json.results || [];\n\nconst records = pages.filter(p => (p.properties?.['납부회차']?.select?.name || '').startsWith(year));\nconst nums = records.map(p => parseInt((p.properties?.['납부회차']?.select?.name || '').slice(2), 10) || 0);\nconst maxSeq = nums.length > 0 ? Math.max(...nums) : -1;\nconst seq = String(maxSeq + 1).padStart(2, '0');\nconst paySeq = year + seq;\n\n// 2차 안전장치: 납부회차 기준 중복 체크\nconst isDuplicate = records.some(p =>\n  (p.properties?.['납부회차']?.select?.name || '') === paySeq\n);\nif (isDuplicate) {\n  console.log(`[중복 방지] ${studentName} - ${paySeq} 이미 존재. 실행 중단.`);\n  return [];\n}\n\nconst recordName = `${studentName} | ${paySeq}`;\nreturn [{ json: { studentStudyPageId, studentPageId, fee, isoDate, paySeq, recordName } }];"
