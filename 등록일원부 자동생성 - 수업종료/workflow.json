    {
      "id": "code-02b",
      "name": "Code - 이름 병합",
      "parameters": {
        "jsCode": "const studentData = $json;\nconst prev = $('Code - 수업료 추출').item.json;\nconst studentName = studentData.properties?.['이름']?.title?.[0]?.plain_text || '';\nreturn [{ json: { ...prev, studentName } }];"
      },
      "position": [
        704,
        304
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "http-01",
      "name": "HTTP - 납부회차 조회",
      "parameters": {
        "authentication": "predefinedCredentialType",
        "headerParameters": {
          "parameters": [
            {
              "name": "Notion-Version",
              "value": "2022-06-28"
            }
          ]
        },
        "jsonBody": "={\n  \"filter\": {\n    \"property\": \"Students\",\n    \"relation\": {\n      \"contains\": \"{{ $json.studentPageId }}\"\n    }\n  }\n}",
        "method": "POST",
        "nodeCredentialType": "notionApi",
        "options": {},
        "sendBody": true,
        "sendHeaders": true,
        "specifyBody": "json",
        "url": "https://api.notion.com/v1/databases/55aac51e739c4f8e870903cb1eb252b6/query"
      },
      "position": [
        960,
        304
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2
    },
    {
      "id": "code-03",
      "name": "Code - 납부회차 계산",
      "parameters": {
        "jsCode": "const prev = $('Code - 이름 병합').item.json;\nconst { studentName, studentStudyPageId, studentPageId, isoDate, year, fee } = prev;\nconst pages = $input.first().json.results || [];\n\nconst records = pages.filter(p => (p.properties?.['납부회차']?.select?.name || '').startsWith(year));\nconst nums = records.map(p => parseInt((p.properties?.['납부회차']?.select?.name || '').slice(2), 10) || 0);\nconst maxSeq = nums.length > 0 ? Math.max(...nums) : -1;\nconst seq = String(maxSeq + 1).padStart(2, '0');\nconst paySeq = year + seq;\n\n// 2차 안전장치: 납부회차 기준 중복 체크\nconst isDuplicate = records.some(p =>\n  (p.properties?.['납부회차']?.select?.name || '') === paySeq\n);\nif (isDuplicate) {\n  console.log(`[중복 방지] ${studentName} - ${paySeq} 이미 존재. 실행 중단.`);\n  return [];\n}\n\nconst recordName = `${studentName} | ${paySeq}`;\nreturn [{ json: { studentStudyPageId, studentPageId, fee, isoDate, paySeq, recordName } }];"
      },
      "position": [
        1220,
        304
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "http-02",
      "name": "HTTP - 등록일원부 레코드 생성",
      "parameters": {
