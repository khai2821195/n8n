      {
        "id": "code-01",
        "name": "Code - 종료 체크 및 데이터 추출",
        "parameters": {
          "jsCode": "const page = $input.first().json;\nconst props = page.properties || {};\n\n// 수업완료 체크\nconst isEnded = props['수업완료']?.checkbox === true;\nif (!isEnded) return [];\n\n// ✅ 등록일원부생성 체크박스가 이미 true면 중단 (중복 방지 핵심)\nconst alreadyCreated = props['등록일원부생성']?.checkbox === true;\nif (alreadyCreated) return [];\n\nconst sessionItems = props['수업회차']?.multi_select || [];\nconst sessionItem = sessionItems.find(s => /\\d/.test(s.name));\nconst sessionCount = sessionItem ? parseInt(sessionItem.name) : null;\n\nconst bunArr = props['수업구분']?.rollup?.array || [];\nconst bunName = bunArr[0]?.select?.name || '';\nconst classCount = parseInt(bunName.replace(/[^0-9]/g, '')) || null;\n\nif (sessionCount === null || classCount === null) return [];\nif (sessionCount !== classCount) return [];\n\nconst studentStudyPageId = page.id;\nconst studentPageId = props['Students']?.relation?.[0]?.id || '';\nif (!studentPageId) return [];\nconst classPageId = props['Class']?.relation?.[0]?.id || '';\nif (!classPageId) return [];\n\nconst rollupArr = props['다음수업일']?.rollup?.array || [];\nconst dateStr = rollupArr[0]?.formula?.string || '';\nlet isoDate = new Date().toISOString().split('T')[0];\nif (dateStr) {\n  const m = dateStr.match(/(\\d{4})년\\s*(\\d{1,2})월\\s*(\\d{1,2})일/);\n  if (m) isoDate = `${m[1]}-${String(m[2]).padStart(2,'0')}-${String(m[3]).padStart(2,'0')}`;\n}\n\nconst year = String(new Date().getFullYear()).slice(2);\nreturn [{ json: { studentStudyPageId, studentPageId, classPageId, isoDate, year } }];"
        },
