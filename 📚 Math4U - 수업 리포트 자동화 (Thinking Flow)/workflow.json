    {
      "id": "ai-report-generate",
      "name": "🤖 AI 리포트 생성",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        320,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-lite:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "sendQuery": false,
        "queryParameters": {},
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ contents: [{ parts: [{ text: '당신은 대치Math4U 프리미엄 수학학원의 수업 리포트 작성 전문가입니다.\\n아래 수업 데이터를 바탕으로 학부모에게 전달할 \\'The Thinking Flow(사고의 궤적)\\' 리포트를 작성해주세요.\\n\\n[수업 데이터]\\n- 학생: \\'' + $(\\'📊 데이터 파싱\\').item.json.studentName + \\'\\n- 날짜: \\' + $(\\'📊 데이터 파싱\\').item.json.lessonDate + \\'\\n- 단원: \\' + $(\\'📊 데이터 파싱\\').item.json.subjectUnit + \\'\\n- 원리 발견(Discovery): \\' + $(\\'📊 데이터 파싱\\').item.json.discovery + \\'\\n- 일반화 확장(Generalization): \\' + $(\\'📊 데이터 파싱\\').item.json.generalization + \\'\\n- 논리적 지속성(Concentration): \\' + $(\\'📊 데이터 파싱\\').item.json.concentration + \\'\\n- 유레카 모먼트: \\' + $(\\'📊 데이터 파싱\\').item.json.eureka + \\'\\n- 취약점: \\' + $(\\'📊 데이터 파싱\\').item.json.weakness + \\'\\n- 강사 코멘트: \\' + $(\\'📊 데이터 파싱\\').item.json.presetMessage + \\'\\n\\n[리포트 작성 규칙]\\n1. 카카오알림톡 1,000자 이내로 작성\\n2. 절제되고 전문적인 톤 (에르메스급 품격)\\n3. \\'기본 개념의 일반화\\'\\ub97c 통한 사고력 성장에 포커스\\n4. 학부모가 자녀의 지적 성장을 체감할 수 있도록 구체적으로\\n5. 다음 구조를 반드시 지킬 것:\\n   📌 이번 수업의 핵심 원리 (1문장)\\n   🧠 사고의 흐름 (2-3문장)\\n   ✨ 오늘의 성장 포인트\\n   📖 다음 단계 안내 (1문장)\\n\\nJSON으로만 반환(백틱 없이): {\"reportBody\":\"...\"}\\' }] }], generationConfig: { temperature: 0.7, maxOutputTokens: 800 } }) }}",
        "options": {
          "timeout": 60000
        }
      }
    },
    {
      "id": "parse-ai-response",
      "name": "🔧 AI 응답 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        0
      ],
      "parameters": {
        "jsCode": "const geminiResponse = $input.item.json;\n\n// Gemini 응답 구조: candidates[0].content.parts[0].text\nlet rawText = '';\ntry {\n  rawText = geminiResponse.candidates[0].content.parts[0].text;\n} catch(e) {\n  rawText = '{\"reportBody\": \"리포트 생성 중 오류가 발생했습니다.\"}';\n}\n\n// JSON 파싱 (마크다운 코드블록 제거 후)\nlet reportBody = '';\ntry {\n  const cleaned = rawText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  const parsed = JSON.parse(cleaned);\n  reportBody = parsed.reportBody;\n} catch(e) {\n  reportBody = rawText;\n}\n\nconst studentData = $('📊 데이터 파싱').item.json;\nconst notionData = $('🔍 Notion 학생 조회').item.json;\n\n// 학부모 연락처 추출\nlet parentPhone = '';\ntry {\n  parentPhone = notionData.properties?.['상담연락처']?.phone_number ??\n                notionData.properties?.['학부모연락처']?.phone_number ??\n                notionData.properties?.['연락처']?.phone_number ?? '';\n} catch(e) {\n  parentPhone = '';\n}\n\nreturn [{\n  json: {\n    studentName: studentData.studentName,\n    lessonDate: studentData.lessonDate,\n    parentPhone: parentPhone,\n    reportBody: reportBody,\n    notionPageId: notionData.id ?? ''\n  }\n}];"
      }
    },
