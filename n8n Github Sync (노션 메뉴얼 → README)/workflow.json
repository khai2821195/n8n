      "id": "notion-db",
      "name": "노션 DB 조회",
      "position": [
        -288,
        16
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2
    },
    {
      "parameters": {
        "jsCode": "var n8nWFs = $('n8n 전체 WF 목록 조회').first().json.data || [];\nvar notionPages = $('노션 DB 조회').first().json.results || [];\n\nvar n8nMap = {};\nfor (var i = 0; i < n8nWFs.length; i++) {\n  n8nMap[n8nWFs[i].id] = { name: n8nWFs[i].name, isArchived: n8nWFs[i].isArchived };\n}\n\nvar notionIds = {};\nfor (var j = 0; j < notionPages.length; j++) {\n  var p = notionPages[j];\n  var wid = '';\n  if (p.properties['Workflow ID'] && p.properties['Workflow ID'].rich_text && p.properties['Workflow ID'].rich_text.length > 0) {\n    wid = p.properties['Workflow ID'].rich_text[0].plain_text;\n  }\n  if (wid) notionIds[wid] = p.id;\n}\n\n// 아카이브되거나 n8n에 없는 WF → 노션에서 삭제\nvar toDelete = [];\nfor (var wid in notionIds) {\n  if (!n8nMap[wid] || n8nMap[wid].isArchived) {\n    toDelete.push({ json: { _action: 'delete', notionPageId: notionIds[wid], workflowId: wid } });\n  }\n}\n\n// 노션에 없는 활성 WF → 신규 추가\nvar toAdd = [];\nfor (var k = 0; k < n8nWFs.length; k++) {\n  var wf = n8nWFs[k];\n  if (wf.isArchived) continue;\n  if (notionIds[wf.id]) continue;\n  toAdd.push({ json: { _action: 'add', workflowId: wf.id, workflowName: wf.name } });\n}\n\nvar result = toDelete.concat(toAdd);\nif (result.length === 0) {\n  return [{ json: { _noAction: true } }];\n}\nreturn result;"
      },
