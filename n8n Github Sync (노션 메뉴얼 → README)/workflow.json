    {
      "parameters": {
        "jsCode": "// 루프 안 - 현재 아이템만 사용\n// Loop Over Items가 배치 1개씩 넘겨주므로\n// $input.item = n8n WF API 응답\n// $('Loop Over Items').item = 현재 루프 아이템 (메타)\nvar wfData = $input.item.json;\nvar meta = $('Loop Over Items').item.json;\n\nif (wfData.nodes) {\n  for (var j = 0; j < wfData.nodes.length; j++) {\n    if (wfData.nodes[j].credentials) delete wfData.nodes[j].credentials;\n  }\n}\nvar jsonContent = JSON.stringify(wfData, null, 2);\nvar jsonBase64 = Buffer.from(jsonContent).toString('base64');\n\nreturn [{ json: {\n  workflowId: meta.workflowId,\n  workflowName: meta.workflowName,\n  notionPageId: meta.notionPageId,\n  category: meta.category,\n  folderPath: meta.folderPath,\n  jsonBase64: jsonBase64\n} }];"
      },
