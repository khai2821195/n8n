    {
      "parameters": {
        "jsCode": "var results = $input.first().json.results || [];\nvar items = [];\nfor (var i = 0; i < results.length; i++) {\n  var page = results[i];\n  var props = page.properties;\n  var workflowId = '';\n  if (props['Workflow ID'] && props['Workflow ID'].rich_text && props['Workflow ID'].rich_text.length > 0) {\n    workflowId = props['Workflow ID'].rich_text[0].plain_text;\n  }\n  var workflowName = '';\n  if (props['Workflow Name'] && props['Workflow Name'].title && props['Workflow Name'].title.length > 0) {\n    workflowName = props['Workflow Name'].title[0].plain_text;\n  }\n  var notionPageId = '';\n  if (props['Notion Page ID'] && props['Notion Page ID'].rich_text && props['Notion Page ID'].rich_text.length > 0) {\n    notionPageId = props['Notion Page ID'].rich_text[0].plain_text;\n  }\n  var category = '공통';\n  if (props['Category'] && props['Category'].select) {\n    category = props['Category'].select.name;\n  }\n  if (!workflowId || !notionPageId) continue;\n  if (workflowName.indexOf('🗑️') !== -1) continue;\n  var safeName = workflowName.replace(/[\\/\\\\:*?\"<>|]/g, '-').trim();\n  items.push({ json: { workflowId: workflowId, workflowName: workflowName, notionPageId: notionPageId, category: category, folderPath: safeName } });\n}\nreturn items;"
      },
