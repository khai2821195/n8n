    {
      "parameters": {
        "jsCode": "var data = $input.item.json;\nvar prev = $('JSON 준비').item.json;\nfunction getText(rt) {\n  if (!rt || !Array.isArray(rt)) return '';\n  var s = '';\n  for (var i = 0; i < rt.length; i++) s += rt[i].plain_text || '';\n  return s;\n}\nfunction toMd(b) {\n  if (!b || !b.type) return '';\n  var t = b.type;\n  if (t === 'heading_1') return '# ' + getText(b.heading_1 && b.heading_1.rich_text) + '\\n\\n';\n  if (t === 'heading_2') return '## ' + getText(b.heading_2 && b.heading_2.rich_text) + '\\n\\n';\n  if (t === 'heading_3') return '### ' + getText(b.heading_3 && b.heading_3.rich_text) + '\\n\\n';\n  if (t === 'paragraph') { var tx = getText(b.paragraph && b.paragraph.rich_text); return tx ? tx + '\\n\\n' : '\\n'; }\n  if (t === 'bulleted_list_item') return '- ' + getText(b.bulleted_list_item && b.bulleted_list_item.rich_text) + '\\n';\n  if (t === 'numbered_list_item') return '1. ' + getText(b.numbered_list_item && b.numbered_list_item.rich_text) + '\\n';\n  if (t === 'code') { var lang = (b.code && b.code.language) || ''; return '```' + lang + '\\n' + getText(b.code && b.code.rich_text) + '\\n```\\n\\n'; }\n  if (t === 'quote') return '> ' + getText(b.quote && b.quote.rich_text) + '\\n\\n';\n  if (t === 'divider') return '---\\n\\n';\n  return '';\n}\nvar blocks = data.results || [];\nvar md = '# ' + prev.workflowName + '\\n\\n';\nmd += '> **Category:** ' + prev.category + '  \\n';\nmd += '> **Workflow ID:** `' + prev.workflowId + '`  \\n';\nmd += '> **노션 메뉴얼:** https://www.notion.so/' + prev.notionPageId.replace(/-/g, '') + '  \\n\\n';\nmd += '---\\n\\n';\nfor (var i = 0; i < blocks.length; i++) md += toMd(blocks[i]);\nvar readmeBase64 = Buffer.from(md).toString('base64');\nreturn [{ json: { workflowId: prev.workflowId, workflowName: prev.workflowName, notionPageId: prev.notionPageId, category: prev.category, folderPath: prev.folderPath, readmeBase64: readmeBase64 } }];"
      },
