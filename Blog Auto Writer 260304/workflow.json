      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        2840,
        560
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
