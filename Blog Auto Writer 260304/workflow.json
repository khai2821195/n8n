        "body": "={\"parent\":{\"database_id\":\"YOUR_NOTION_DATABASE_ID\"},\"properties\":{\"제목\":{\"title\":[{\"text\":{\"content\":\"[Blog] \"+$json.blog_topic}}]},\"상태\":{\"select\":{\"name\":\"초안완성\"}},\"품질점수\":{\"number\":$json.quality_score},\"반복횟수\":{\"number\":$json.loop_count}},\"children\":[{\"object\":\"block\",\"type\":\"paragraph\",\"paragraph\":{\"rich_text\":[{\"type\":\"text\",\"text\":{\"content\":$json.draft_content.substring(0,2000)}}]}}]}"
      },
      "onError": "continueRegularOutput"
    },
    {
