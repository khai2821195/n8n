        "sendBody": true,
        "contentType": "raw",
        "body": "={\"model\":\"claude-sonnet-4-20250514\",\"max_tokens\":4000,\"system\":\"블로그 편집 전문가. [참고자료]만 활용, 외부정보 추가 금지.\",\"messages\":[{\"role\":\"user\",\"content\":\"[보완지시]\\n\"+$json.improvements+\"\\n\\n[참고자료]\\n\"+$json.merged_contents+\"\\n\\n[현재초안]\\n\"+$json.draft_content+\"\\n\\n보완된 완성 글 전체를 작성해주세요.\"}]}"
      }
    },
    {
      "id": "node-update",
      "name": "보강된 초안 업데이트",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3060,
        560
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item=$input.first();\nconst newContent=item.json.content&&item.json.content[0]?item.json.content[0].text:item.json.draft_content;\nreturn [{json:{...item.json,draft_content:newContent}}];"
      }
    },
    {
      "id": "node-save",
      "name": "노션에 초안 저장",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
